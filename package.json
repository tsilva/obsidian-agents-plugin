{
  "name": "obsidian-agents",
  "version": "1.0.0",
  "description": "Launch Claude Code from your Obsidian vault",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "install-plugin": "bash install.sh"
  },
  "keywords": ["obsidian", "claude", "terminal"],
  "author": "tsilva",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.25.0",
    "obsidian": "latest",
    "tslib": "^2.7.0",
    "typescript": "^5.6.0"
  }
}
